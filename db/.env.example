# Copy this file to `.env` in this same `db/` folder.
# `.env` is gitignored; safe to put real passwords and URLs here.
# This file is for the db branch / server repo only (not the public GitHub app repo).

# --- Docker MySQL (docker compose) ---
MYSQL_HOST_PORT=3306
MYSQL_DATABASE=strype_analytics
MYSQL_ROOT_PASSWORD=rootpass
MYSQL_USER=strype
MYSQL_PASSWORD=strypepass

# --- Local analytics ingest (editor + ingest-server) ---
# Port must match the host in VITE_ANALYTICS_INGEST_URL.
INGEST_PORT=8787
VITE_ANALYTICS_INGEST_URL=http://127.0.0.1:8787/

# --- Ingest server → MySQL (same credentials as docker by default) ---
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
